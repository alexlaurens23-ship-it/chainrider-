SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
JWT_SECRET=
ADMIN_KEY=
# Optional: free CoinGecko demo API key. Without it, keyless access is limited
# to the past 365 days, so ALL-period maps (days=max) fail with 401.
COINGECKO_API_KEY=
# Telegram payout bot (Option B). Both required to enable it; unset = disabled.
# The bot only DMs payout instructions and marks payouts paid when YOU reply
# /paid <id> <txSig>. It never holds keys or sends SOL. It obeys ONLY the admin
# user id below — every other sender is ignored.
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_USER_ID=
# DEV-ONLY: set to 1 to enable the force-close-window admin endpoint
# (POST /api/admin/windows/:id/close) for testing the payout flow on demand.
# Leave BLANK in production — the endpoint 404s unless this is exactly "1".
DEV_FORCE_CLOSE=
